{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2020"],
    "outDir": "dist",
    "resolveJsonModule": true
  },
  "include": ["tests/**/*.ts", "src/**/*.ts", "**/*.ts"]
}
